{
  "name": "backend",
  "version": "1.0.0",
  "description": "MERN Task Management Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:all": "npm-run-all --parallel dev worker",
    "worker": "node workers/emailWorker.js",
    "seed:admin": "node seedAdmin.js",
    "seed:permissions": "node seedPermissions.js",
    "seed": "node seedAdmin.js && node seedPermissions.js",
    "format": "prettier --write \"**/*.js\"",
    "build": "esbuild server.js --bundle --platform=node --target=node18 --minify --outfile=dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "nodemon": "^3.1.11",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1"
  }
}